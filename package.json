{
  "name": "dota-example-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimum TypeScript bot scaffold for Defense of the Agents",
  "scripts": {
    "build": "tsc -p tsconfig.json",
